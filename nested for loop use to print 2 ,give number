#include<iostream>
using namespace std;
int main(){
    int i,j,k;
    cout<<"Enter no of rows";
    cin>>i;
    for(j=1;j<=i;j++){
        for(k=1;k<=j;k++)
        cout<<j+k;
        cout<<"\n";}
        
        
        
return 0;
}

